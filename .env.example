# ============================================
# SaaS E-commerce Platform - Environment Config
# ============================================

# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://saas_ecom:saas_ecom_dev_pass@localhost:5432/saas_ecom_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl rand -base64 48)
JWT_SECRET=replace-with-a-32-character-minimum-secret-key

# Email (Resend) - optional in dev
RESEND_API_KEY=
FROM_EMAIL=noreply@example.com

# S3 Storage - optional in dev (uses local uploads/ folder in development)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Payment (Stripe) - optional in dev
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Analytics
MIXPANEL_TOKEN=

# Logging
LOG_LEVEL=debug

# CORS - comma-separated origins for production (e.g., "*.myplatform.com,https://admin.myplatform.com")
CORS_ORIGINS=

# Reverse proxy hops (for accurate client IP behind load balancers/CDN)
# Set to the number of reverse proxies between the internet and your app:
#   1 = single proxy (e.g., Nginx reverse proxy)
#   2 = Cloudflare → ALB → app
#   3 = Cloudflare → ALB → Kubernetes ingress → app
TRUST_PROXY_HOPS=1