# Spaceship — Caddy Reverse Proxy (IP-based fallback)
# This file is used when no domains are configured.
# When domains ARE configured, deploy-remote.sh generates a domain-aware Caddyfile automatically.
{
	auto_https off
	admin 0.0.0.0:2019
}

:80 {
	# API routes — preserve /api prefix so backend routes match
	@api path /api /api/*
	handle @api {
		reverse_proxy backend:3000 {
			header_up Host {host}
			header_down X-Frame-Options "DENY"
			header_down X-Content-Type-Options "nosniff"
			header_down X-XSS-Protection "1; mode=block"
			header_down Referrer-Policy "strict-origin-when-cross-origin"
			header_down Permissions-Policy "geolocation=(), microphone=(), camera()"
			header_down Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			header_down Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			header_down -Server
		}
		encode gzip zstd
	}

	# Health checks
	@health path /health /health/*
	handle @health {
		reverse_proxy backend:3000 {
			header_up Host {host}
			header_down X-Content-Type-Options "nosniff"
			header_down Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			header_down Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			header_down -Server
		}
	}

	# Dashboard
	@dashboard path /dashboard /dashboard/*
	handle @dashboard {
		reverse_proxy dashboard:3001 {
			header_down X-Frame-Options "SAMEORIGIN"
			header_down X-Content-Type-Options "nosniff"
			header_down X-XSS-Protection "1; mode=block"
			header_down Referrer-Policy "strict-origin-when-cross-origin"
			header_down Permissions-Policy "geolocation=(), microphone=(), camera()"
			header_down Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			header_down Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			header_down -Server
		}
		encode gzip zstd
	}

	# Food Storefront — Brio theme stores and direct paths
	@store path /store /store/*
	handle @store {
		reverse_proxy storefront-food:3003 {
			header_down X-Frame-Options "SAMEORIGIN"
			header_down X-Content-Type-Options "nosniff"
			header_down X-XSS-Protection "1; mode=block"
			header_down Referrer-Policy "strict-origin-when-cross-origin"
			header_down Permissions-Policy "geolocation=(), microphone=(), camera()"
			header_down Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			header_down Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			header_down -Server
		}
		encode gzip zstd
	}

	@menu path /menu /menu/*
	handle @menu {
		reverse_proxy storefront-food:3003 {
			header_down X-Frame-Options "SAMEORIGIN"
			header_down X-Content-Type-Options "nosniff"
			header_down X-XSS-Protection "1; mode=block"
			header_down Referrer-Policy "strict-origin-when-cross-origin"
			header_down Permissions-Policy "geolocation=(), microphone=(), camera()"
			header_down Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			header_down Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			header_down -Server
		}
		encode gzip zstd
	}

	@cart path /cart /cart/*
	handle @cart {
		reverse_proxy storefront-food:3003 {
			header_down X-Frame-Options "SAMEORIGIN"
			header_down X-Content-Type-Options "nosniff"
			header_down X-XSS-Protection "1; mode=block"
			header_down Referrer-Policy "strict-origin-when-cross-origin"
			header_down Permissions-Policy "geolocation=(), microphone=(), camera()"
			header_down Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			header_down Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			header_down -Server
		}
		encode gzip zstd
	}

	@checkout path /checkout /checkout/*
	handle @checkout {
		reverse_proxy storefront-food:3003 {
			header_down X-Frame-Options "SAMEORIGIN"
			header_down X-Content-Type-Options "nosniff"
			header_down X-XSS-Protection "1; mode=block"
			header_down Referrer-Policy "strict-origin-when-cross-origin"
			header_down Permissions-Policy "geolocation=(), microphone=(), camera()"
			header_down Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			header_down Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			header_down -Server
		}
		encode gzip zstd
	}

	# Default — Landing Page
	handle {
		reverse_proxy landing:3004 {
			header_down X-Frame-Options "SAMEORIGIN"
			header_down X-Content-Type-Options "nosniff"
			header_down X-XSS-Protection "1; mode=block"
			header_down Referrer-Policy "strict-origin-when-cross-origin"
			header_down Permissions-Policy "geolocation=(), microphone=(), camera()"
			header_down Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			header_down Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			header_down -Server
		}
		encode gzip zstd
	}
}
