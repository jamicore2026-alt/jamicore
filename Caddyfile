}

# Default / fallback — IP-based access or general storefront domain
:80 {
	# API routes — preserve /api prefix so backend routes match
	handle /api/* {
		reverse_proxy backend:3000
		encode gzip zstd
		header {
			X-Frame-Options DENY
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	# Health checks
	handle /health {
		reverse_proxy backend:3000
		header {
			X-Content-Type-Options nosniff
			-Server
		}
	}

	# Dashboard
	handle /dashboard/* {
		reverse_proxy dashboard:3001
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	# Food Storefront — Brio theme stores
	handle /store/* {
		reverse_proxy storefront-food:3003
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	# Food Storefront — direct menu/cart/checkout paths
	handle /menu/* {
		reverse_proxy storefront-food:3003
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	handle /cart {
		reverse_proxy storefront-food:3003
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	handle /checkout {
		reverse_proxy storefront-food:3003
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	# Default — General Storefront
	handle {
		reverse_proxy storefront:3002
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}
}
