# Spaceship — Caddy Reverse Proxy (IP-based path routing)
# For domain-based routing, update once DNS A records are configured.
{
	auto_https off
	admin off
}

:80 {
	# API routes — preserve /api prefix so backend routes match
	handle /api/* {
		reverse_proxy backend:3000
		encode gzip zstd
		header {
			X-Frame-Options DENY
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	# Health checks
	handle /health {
		reverse_proxy backend:3000
		header {
			X-Content-Type-Options nosniff
			-Server
		}
	}

	# Default → Storefront
	handle {
		reverse_proxy storefront:3002
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}
}
