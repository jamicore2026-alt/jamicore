# Spaceship — Caddy Reverse Proxy (IP-based fallback)
# This file is used when no domains are configured.
# When domains ARE configured, deploy-remote.sh generates a domain-aware Caddyfile automatically.
{
	auto_https off
	admin off
}

:80 {
	# API routes — preserve /api prefix so backend routes match
	handle /api/* {
		reverse_proxy backend:3000
		encode gzip zstd
		header {
			X-Frame-Options DENY
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	# Health checks
	handle /health {
		reverse_proxy backend:3000
		header {
			X-Content-Type-Options nosniff
			-Server
		}
	}

	# Dashboard
	handle /dashboard/* {
		reverse_proxy dashboard:3001
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	# Food Storefront — Brio theme stores and direct paths
	handle /store/* {
		reverse_proxy storefront-food:3003
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	handle /menu/* {
		reverse_proxy storefront-food:3003
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	handle /cart {
		reverse_proxy storefront-food:3003
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	handle /checkout {
		reverse_proxy storefront-food:3003
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	# Default — General Storefront
	handle {
		reverse_proxy storefront:3002
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}
}
