# Spaceship — Caddy Reverse Proxy (IP-based fallback)
# This file is used when no domains are configured.
# When domains ARE configured, deploy-remote.sh generates a domain-aware Caddyfile automatically.
{
	auto_https off
	admin off
}

:80 {
	# API routes — preserve /api prefix so backend routes match
	@api path /api /api/*
	handle @api {
		reverse_proxy backend:3000 {
			header_up Host {host}
		}
		encode gzip zstd
		header {
			defer
			X-Frame-Options DENY
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera()"
			Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			-Server
		}
	}

	# Health checks
	@health path /health /health/*
	handle @health {
		reverse_proxy backend:3000 {
			header_up Host {host}
		}
		header {
			defer
			X-Content-Type-Options nosniff
			Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			-Server
		}
	}

	# Dashboard
	@dashboard path /dashboard /dashboard/*
	handle @dashboard {
		reverse_proxy dashboard:3001
		encode gzip zstd
		header {
			defer
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera()"
			Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			-Server
		}
	}

	# Food Storefront — Brio theme stores and direct paths
	@store path /store /store/*
	handle @store {
		reverse_proxy storefront-food:3003
		encode gzip zstd
		header {
			defer
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera()"
			Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			-Server
		}
	}

	@menu path /menu /menu/*
	handle @menu {
		reverse_proxy storefront-food:3003
		encode gzip zstd
		header {
			defer
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera()"
			Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			-Server
		}
	}

	@cart path /cart /cart/*
	handle @cart {
		reverse_proxy storefront-food:3003
		encode gzip zstd
		header {
			defer
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera()"
			Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			-Server
		}
	}

	@checkout path /checkout /checkout/*
	handle @checkout {
		reverse_proxy storefront-food:3003
		encode gzip zstd
		header {
			defer
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera()"
			Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			-Server
		}
	}

	# Default — General Storefront
	handle {
		reverse_proxy storefront:3002
		encode gzip zstd
		header {
			defer
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera()"
			Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
			Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
			-Server
		}
	}
}
