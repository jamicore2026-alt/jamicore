# Spaceship — Caddy Reverse Proxy
# Configure DNS A records to point all subdomains to the VM IP.
{
	auto_https off
	admin off
}

# Subdomain-based routing when domains are configured
api.{$API_DOMAIN}, {$API_DOMAIN} {
	handle /api/* {
		reverse_proxy backend:3000
		encode gzip zstd
		header {
			X-Frame-Options DENY
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	handle /health {
		reverse_proxy backend:3000
		header {
			X-Content-Type-Options nosniff
			-Server
		}
	}

	handle {
		reverse_proxy backend:3000
		encode gzip zstd
		header {
			X-Frame-Options DENY
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}
}

{$DASHBOARD_DOMAIN} {
	handle /dashboard/* {
		reverse_proxy dashboard:3001
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}

	handle {
		reverse_proxy dashboard:3001
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
	}
}

{$STOREFRONT_FOOD_DOMAIN} {
	handle {
		reverse_proxy storefront-food:3003
		encode gzip zstd
		header {
			X-Frame-Options SAMEORIGIN
			X-Content-Type-Options nosniff
			X-XSS-Protection "1; mode=block"
			Referrer-Policy strict-origin-when-cross-origin
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			-Server
		}
