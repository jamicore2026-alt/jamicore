# ============================================
# SaaS E-commerce Platform - Backend Environment Config
# ============================================

# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://saas_ecom:YOUR_DEV_PASSWORD@localhost:5432/saas_ecom_dev

# Redis
REDIS_URL=redis://:your-redis-password@localhost:6379

# JWT (generate with: openssl rand -base64 48)
JWT_SECRET=replace-with-a-32-character-minimum-secret-key

# Email (Resend) - optional in dev
RESEND_API_KEY=
FROM_EMAIL=noreply@example.com

# S3 Storage - optional in dev (local first)
S3_BUCKET=
S3_BACKUP_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Payment (Stripe) - optional in dev
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Payment Config Encryption (REQUIRED in production — 64-char hex)
# Generate with: openssl rand -hex 32
PAYMENT_CONFIG_ENCRYPTION_KEY=

# Analytics
MIXPANEL_TOKEN=

# Observability
SENTRY_DSN=

# Swagger Docs Auth (dev only)
SWAGGER_USER=admin
SWAGGER_PASSWORD=docs

# Logging
LOG_LEVEL=debug