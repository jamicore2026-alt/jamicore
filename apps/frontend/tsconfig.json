{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "lib": ["esnext", "dom", "dom.iterable"],
    "types": ["svelte"]
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", ".svelte-kit/ambient.d.ts"]
}
