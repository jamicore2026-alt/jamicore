{
  "dashboard": {
    "id": null,
    "title": "Spaceship Health",
    "tags": ["spaceship", "health"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Backend Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"spaceship-backend\"}",
            "legendFormat": "Backend"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Memory Usage (RSS)",
        "type": "gauge",
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job=\"spaceship-backend\"} / 1024 / 1024",
            "legendFormat": "RSS MB"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "decmbytes",
            "max": 512,
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 300},
                {"color": "red", "value": 450}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Service Health",
        "type": "table",
        "targets": [
          {
            "expr": "up{job=~\"spaceship-.*\"}",
            "format": "table",
            "instant": true
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "transformations": [
          {
            "id": "organize",
            "options": {
              "indexByName": {"job": 0, "instance": 1, "Value": 2}
            }
          }
        ]
      }
    ]
  },
  "overwrite": true
}
