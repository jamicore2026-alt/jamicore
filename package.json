{
  "name": "saas-ecommerce",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run e2e",
    "test:e2e:storefront": "pnpm --filter storefront e2e",
    "test:e2e:dashboard": "pnpm --filter dashboard e2e",
    "db:generate": "pnpm --filter backend db:generate",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:studio": "pnpm --filter backend db:studio",
    "db:seed": "pnpm --filter backend db:seed",
    "clean": "turbo run clean && rm -rf node_modules",
    "check:security": "pnpm run check:console && pnpm run check:types && pnpm run check:storeid && pnpm run check:prehandler",
    "check:console": "grep -r 'console.log' apps/backend/src/ && echo 'Found console.log' || echo 'No console.log found'",
    "check:types": "pnpm --filter backend typecheck",
    "check:storeid": "grep -r 'body.storeId' apps/backend/src/ && echo 'Found body.storeId' || echo 'No body.storeId found'",
    "check:prehandler": "grep -r 'preHandler' apps/backend/src/routes/ && echo 'Found inline preHandler' || echo 'No inline preHandler found'"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte-eslint-parser": "^1.6.0",
    "turbo": "^2.9.5",
    "typescript-eslint": "^8.58.2"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0",
      "fast-xml-parser": "^5.7.0",
      "uuid": "^14.0.0"
    }
  }
}