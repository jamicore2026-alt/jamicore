{
  "name": "@repo/shared-utils",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./cookies": {
      "types": "./src/cookies.ts",
      "default": "./src/cookies.ts"
    },
    "./jwt": {
      "types": "./src/jwt.ts",
      "default": "./src/jwt.ts"
    },
    "./format": {
      "types": "./src/format/index.ts",
      "default": "./src/format/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "echo 'shared-utils: no build needed'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "date-fns": "^4"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^4.1.5"
  }
}